<Window x:Class="EkranCeviri.SettingsWindow"
        Icon="TR.ico"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="440" Width="340" 
        Background="#1E1E1E" WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize" WindowStyle="ToolWindow">

    <StackPanel Margin="20">
        <TextBlock Text="⚙️ Application Settings" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

        <TextBlock Text="Translation Engine (API):" Foreground="#AAAAAA" Margin="0,0,0,5"/>
        <ComboBox x:Name="CmbApi" Margin="0,0,0,15" SelectedIndex="0">
            <ComboBoxItem Content="Google Translate (Fast)"/>
            <ComboBoxItem Content="Yandex Translate (Better Context)"/>
        </ComboBox>

        <TextBlock Text="Source Language:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
        <ComboBox x:Name="CmbKaynakDil" Margin="0,0,0,15" SelectedIndex="0">
            <ComboBoxItem Content="English"/>
            <ComboBoxItem Content="Turkish"/>
            <ComboBoxItem Content="Russian"/>
            <ComboBoxItem Content="Spanish"/>
            <ComboBoxItem Content="French"/>
            <ComboBoxItem Content="Italian"/>
            <ComboBoxItem Content="German"/>
        </ComboBox>

        <TextBlock Text="Target Language:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
        <ComboBox x:Name="CmbHedefDil" Margin="0,0,0,15" SelectedIndex="1">
            <ComboBoxItem Content="English"/>
            <ComboBoxItem Content="Turkish"/>
            <ComboBoxItem Content="Russian"/>
            <ComboBoxItem Content="Spanish"/>
            <ComboBoxItem Content="French"/>
            <ComboBoxItem Content="Italian"/>
            <ComboBoxItem Content="German"/>
        </ComboBox>

        <TextBlock Text="Shortcut Key:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
        <ComboBox x:Name="CmbKisayol" Margin="0,0,0,15" SelectedIndex="0">
            <ComboBoxItem Content="Ctrl + Alt + X"/>
            <ComboBoxItem Content="Ctrl + Shift + C"/>
            <ComboBoxItem Content="Alt + Z"/>
        </ComboBox>

        <CheckBox x:Name="ChkBaslangic" Content="Start with Windows" Foreground="White" Margin="0,0,0,15"/>

        <TextBlock Text="* Restart the app to apply new shortcut keys." Foreground="#888888" FontSize="11" Margin="0,0,0,10" HorizontalAlignment="Center" FontStyle="Italic"/>

        <Button Content="Save and Close" Background="#007ACC" Foreground="White" Padding="8" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnKaydet_Click"/>
    </StackPanel>
</Window>